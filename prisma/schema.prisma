generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String?   @unique
  phone           String    @unique
  password        String
  firstName       String?
  lastName        String?
  activated       Boolean   @default(false)
  roles           String[]  @default(["CLIENT"])
  verified        Boolean   @default(false)
  fluxIn          Float?    @default(0)
  fluxOut         Float?    @default(0)
  referralCode    String?
  profession      String?
  matricule       String?
  service         String?
  country         String?   @default("Cameroun")
  joiningYear     Int?
  accountNumber   String?   @unique
  uniqueKey       String?   @unique
  documentType    String?   // CNI, PASSPORT
  documentNumber  String?
  documentUrl     String?
  ribUrl          String?
  referrerName    String?
  address         String?
  addressImageUrl String?
  countryCode     String?
  swiftCode       String?   @default("")
  averageIncome   Float?
  beneficiaries   Json?     @default("[]")
  emergencyContacts Json?   @default("[]")
  kycStatus       String?   @default("IDLE") // IDLE, PENDING, APPROVED, REJECTED
  createdAt       DateTime? @default(now())
  approvedAt      DateTime?
  dueDate         DateTime?
  penaltyAmount   Float?    @default(0)
  updatedAt       DateTime? @updatedAt
  tokenVersion    Int       @default(0)
  preferredTheme  String    @default("SYSTEM")
  locale          String    @default("fr")
  timezone        String    @default("Africa/Douala")
  emailNotifications Boolean @default(true)
  transactionNotifications Boolean @default(true)
  securityNotifications Boolean @default(true)
  pushNotifications Boolean @default(true)
  balancePrivacy  Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  mfaSecretEncrypted String?
  mfaRecoveryCodeHashes String[] @default([])
  mfaVerifiedAt   DateTime?
  mfaLastUsedStep Int?

  referredBy      User?     @relation("UserReferrals", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referredById    String?   @db.ObjectId
  referrals       User[]    @relation("UserReferrals")

  accountIds      String[]  @db.ObjectId @map("accountList")
  transactions    Transaction[]
  transactionIntents TransactionIntent[]
  externalPayments ExternalPayment[]
  mfaEnrollments  MfaEnrollment[]
  pushSubscriptions PushSubscription[]
  notifications   Notification[]
  receipts        Receipt[]

  userGroups      UserGroup[] @relation(fields: [userGroupIds], references: [id])
  userGroupIds    String[]    @db.ObjectId
  
  cotisationGroups   CotisationGroup[] @relation(fields: [cotisationGroupIds], references: [id])
  cotisationGroupIds String[]          @db.ObjectId
  
  loans           Loan[]

  @@map("users")
}

model MfaEnrollment {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  userId              String    @db.ObjectId
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  secretEncrypted     String
  confirmationOtpHash String
  otpExpiresAt        DateTime
  expiresAt           DateTime
  attempts            Int       @default(0)
  deliveryChannel     String
  deliveryDestination String
  deliveryVerifiedAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId])
  @@index([expiresAt])
  @@map("mfa_enrollments")
}

model Loan {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id])
  transactionId   String?   @db.ObjectId
  amount          Float
  interestRate    Float     @default(0)
  totalInterest   Float?    @default(0)
  duration        Int       // in months
  purpose         String?
  status          String    @default("PENDING") // PENDING, VALIDATED, CONFIRMED, APPROVED, REJECTED, PAID
  avalistes       Json?     @default("[]")     // List of { userId, amount, interestShare }
  createdBy       String?
  createdById     String?   @db.ObjectId
  validatedBy     String[]  @default([])
  createdAt       DateTime? @default(now())
  approvedAt      DateTime?
  confirmedAt     DateTime?
  disbursedAt     DateTime?
  confirmedBy     String?
  disbursedBy     String?
  dueDate         DateTime?
  penaltyAmount   Float?    @default(0)
  updatedAt       DateTime? @updatedAt

  @@map("loans")
}

model Account {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  currentBalance   Float     @default(0)
  availableBalance Float     @default(0)
  currency         String    @default("XAF")
  type             String    @default("PRINCIPAL")
  createdAt        DateTime? @default(now())
  updatedAt        DateTime? @updatedAt

  @@map("accounts")
}

model Transaction {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?   @map("user") @db.ObjectId
  user            User?     @relation(fields: [userId], references: [id])
  purpose         String?   @map("purpose")
  amount          Float?    @map("destinationAmount")
  status          String?   @default("PENDING")
  transactionRef  String?   @unique @map("transactionRef")
  createdBy       String?   @map("createdBy")
  createdById     String?   @db.ObjectId
  validatedBy     String[]  @default([]) @map("validatedBy")
  targetAccountType String?
  sourceAccountType String?
  currency          String?   @default("XAF")
  operation         Json?
  createdAt       DateTime? @default(now())
  approvedAt      DateTime?
  dueDate         DateTime?
  penaltyAmount   Float?    @default(0)

  @@map("transactions")
}

model CotisationGroup {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  code            String?  @unique
  amount          Float
  maxParticipants Int?     @map("limit_participant")
  nb_participant  Int?     @default(0)
  frequency       String?  @default("MONTHLY")
  currency        String?  @default("XAF")
  status          String?  @default("ACTIF")
  createdAt       DateTime? @default(now())
  approvedAt      DateTime?
  dueDate         DateTime?
  penaltyAmount   Float?    @default(0)

  members         User[]   @relation(fields: [memberIds], references: [id])
  memberIds       String[] @db.ObjectId

  @@map("cotisations")
}

model Currency {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique // e.g., "XAF", "EUR", "USD"
  symbol      String   // e.g., "FCFA", "â‚¬", "$"
  name        String   // e.g., "Franc CFA", "Euro", "US Dollar"
  isActive    Boolean  @default(true)
  rateToBase  Float    @default(1.0) // Rate relative to XAF
  lastUpdated DateTime? @default(now())
  createdAt   DateTime? @default(now())

  @@map("currencies")
}

model UserGroup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  permissions String[] @default([])
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt
  
  users       User[]   @relation(fields: [userIds], references: [id])
  userIds     String[] @db.ObjectId

  @@map("user_groups")
}

model LoanConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
  rate        Float
  duration    Int      // duration in days
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@map("loan_configs")
}

model PasswordReset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_resets")
}

model TransactionIntent {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  user            User      @relation(fields: [userId], references: [id])
  type            String
  payload         Json
  payloadHash     String
  summary         String
  status          String    @default("OTP_PENDING")
  otpHash         String
  otpExpiresAt    DateTime
  otpAttempts     Int       @default(0)
  resendCount     Int       @default(0)
  lastOtpSentAt   DateTime
  deliveryChannel String?
  deliveryDestination String?
  idempotencyKey  String
  result          Json?
  failureReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  consumedAt      DateTime?

  @@unique([userId, idempotencyKey])
  @@index([userId, status, createdAt])
  @@map("transaction_intents")
}

model PushSubscription {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint       String   @unique
  p256dh         String
  auth           String
  userAgent      String?
  enabled        Boolean  @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, enabled])
  @@map("push_subscriptions")
}

model Notification {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String
  type        String
  title       String
  body        String
  data        Json?     @default("{}")
  receiptId   String?   @db.ObjectId
  pushStatus  String    @default("PENDING")
  emailStatus String    @default("PENDING")
  pushSentAt  DateTime?
  emailSentAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, eventId])
  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model Receipt {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId          String
  transactionId    String?  @db.ObjectId
  receiptNumber    String   @unique
  type             String
  title            String
  snapshot         Json
  verificationCode String   @unique
  pdfSha256        String?
  createdAt        DateTime @default(now())

  @@unique([userId, eventId])
  @@index([userId, createdAt])
  @@map("receipts")
}

model OutboxEvent {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  eventKey      String    @unique
  type          String
  aggregateType String
  aggregateId   String
  payload       Json
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  availableAt   DateTime  @default(now())
  lockedAt      DateTime?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, availableAt])
  @@map("outbox_events")
}

model ExternalPayment {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id])
  intentId              String    @unique @db.ObjectId
  provider              String
  method                String
  targetAccountType     String
  amount                Int
  currency              String    @default("XAF")
  reference             String    @unique
  providerSessionId     String?   @unique
  providerPaymentId     String?   @unique
  checkoutUrl           String?
  status                String    @default("PENDING")
  providerStatus        String?
  failureReason         String?
  creditedTransactionId String?   @db.ObjectId
  creditedAt            DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, status, createdAt])
  @@index([provider, status, createdAt])
  @@map("external_payments")
}

model PaymentEvent {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  provider         String
  providerEventId  String
  eventType        String
  paymentReference String?
  payloadHash      String
  processedAt      DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([paymentReference, processedAt])
  @@map("payment_events")
}

model LedgerEntry {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  journalReference String
  paymentId        String   @db.ObjectId
  accountCode      String
  direction        String
  amount           Int
  currency         String   @default("XAF")
  createdAt        DateTime @default(now())

  @@unique([journalReference, accountCode, direction])
  @@index([paymentId, createdAt])
  @@map("ledger_entries")
}

model CotisationPayment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  groupId        String   @db.ObjectId
  periodKey      String
  amount         Float
  transactionRef String   @unique
  createdAt      DateTime @default(now())

  @@unique([userId, groupId, periodKey])
  @@map("cotisation_payments")
}

model SystemBalance {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  code              String   @unique @default("NFS_GLOBAL")
  totalSavings      Float    @default(0)
  totalPrincipal    Float    @default(0)
  totalLoans        Float    @default(0)
  availableLiquidity Float    @default(0)
  lastUpdated       DateTime @default(now())

  @@map("system_balances")
}

model TransferFeeConfig {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  minAmount   Float    // Montant minimum de la tranche
  maxAmount   Float    // Montant maximum de la tranche
  rate        Float    // Taux de frais en pourcentage (ex: 1.5 pour 1.5%)
  flatFee     Float    @default(0) // Frais fixes
  currency    String   @default("XAF") // Devise de la tranche
  isActive    Boolean  @default(true) // Statut de la tranche
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@map("transfer_fee_configs")
}


