NODE_ENV=development
PORT=5000
DATABASE_URL=mongodb://localhost:27017/nfs?replicaSet=rs0
JWT_SECRET=replace-with-at-least-32-random-characters
OTP_HMAC_SECRET=replace-with-a-different-32-character-secret
SESSION_TTL_SECONDS=7200
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=256kb
AUTH_RATE_LIMIT=20
PASSWORD_RESET_RATE_LIMIT=5
TRANSACTION_INTENT_RATE_LIMIT=20
OTP_VERIFY_RATE_LIMIT=15
OTP_RESEND_RATE_LIMIT=5
MAX_TRANSACTION_AMOUNT_XAF=100000000
DEFAULT_LOAN_INTEREST_RATE=5
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
OTP_SMS_WEBHOOK_URL=
OTP_SMS_WEBHOOK_TOKEN=
OTP_DEV_EXPOSE_CODE=false
ENABLE_SWAGGER=false

# --- Payment Gateways / Service Provider Keys ---
# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_HASH=votre_secret_webhook_flutterwave

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Orange Money API
ORANGE_MONEY_CLIENT_ID=xxxxxxxxxxxxxxxx
ORANGE_MONEY_CLIENT_SECRET=xxxxxxxxxxxxxxxx
ORANGE_MONEY_MERCHANT_KEY=xxxxxxxxxxxxxxxx

# MTN Mobile Money API
MTN_MOMO_PRIMARY_KEY=xxxxxxxxxxxxxxxx
MTN_MOMO_SECONDARY_KEY=xxxxxxxxxxxxxxxx
MTN_MOMO_API_USER=xxxxxxxxxxxxxxxx
MTN_MOMO_API_KEY=xxxxxxxxxxxxxxxx

